# Generated by generate.py from templates.yml — DO NOT EDIT BY HAND.

variable "REGISTRY" { default = "althack" }

{# ---------- Targets and repo+name groups ---------- #}
{% for repo, entries in settings.items() %}
  {% for entry in entries if include_eol or ('eol' not in entry) %}
    {% set name = entry['name'] %}
    {% set dockerfile_path = name ~ '.Dockerfile' %}

    {# targets for each stage #}
    {% for t in entry['targets'] %}
      {% set stage = t['target'] %}
      {% set target_name = repo ~ '-' ~ name ~ '-' ~ stage %}

target "{{ target_name }}" {
  context    = "{{ repo }}"
  dockerfile = "{{ dockerfile_path }}"
  target     = "{{ stage }}"
  # Default platforms from templates.yml; override at runtime with --set <group>.*.platform=...
  tags       = [
    "${REGISTRY}/{{ repo }}:{{ name }}-{{ stage }}",
  ]
}
    {% endfor %}

# ---- group per repo+release  ----
group "{{ repo }}-{{ name }}" {
  targets = [
    {%- for t in entry['targets'] -%}
      "{{ repo }}-{{ name }}-{{ t['target'] }}"{% if not loop.last %}, {% endif %}
    {%- endfor -%}
  ]
}

  {% endfor %}
{% endfor %}

{# ---------- Arch-aware groups per entry (only valid stages) ---------- #}
{% for repo, entries in settings.items() %}
  {% for entry in entries if include_eol or ('eol' not in entry) %}
    {% set name = entry['name'] %}
    {% set amd64 = [] %}
    {% set arm64 = [] %}
    {% for t in entry['targets'] %}
      {% set tgt = repo ~ '-' ~ name ~ '-' ~ t['target'] %}
      {% if 'linux/amd64' in t['platforms'] %}
        {% set _ = amd64.append(tgt) %}
      {% endif %}
      {% if 'linux/arm64' in t['platforms'] or 'linux/arm64/v8' in t['platforms'] %}
        {% set _ = arm64.append(tgt) %}
      {% endif %}
    {% endfor %}

    {% if amd64 %}
group "{{ repo }}-{{ name }}-amd64" { targets = [ {{ amd64 | map('tojson') | join(', ') }} ] }
    {% endif %}

    {% if arm64 %}
group "{{ repo }}-{{ name }}-arm64" { targets = [ {{ arm64 | map('tojson') | join(', ') }} ] }
    {% endif %}

  {% endfor %}
{% endfor %}

{# ---------- Family-level groups (e.g., ros2, gz, ignition) ---------- #}
{% for repo, entries in settings.items() %}
  {% set repo_targets = [] %}
  {% for entry in entries if include_eol or ('eol' not in entry) %}
    {% for t in entry['targets'] %}
      {% set _ = repo_targets.append(repo ~ '-' ~ entry['name'] ~ '-' ~ t['target']) %}
    {% endfor %}
  {% endfor %}
group "{{ repo }}" { targets = [ {{ repo_targets | map('tojson') | join(', ') }} ] }
{% endfor %}

# ---- all non-EOL ----
group "default" {
  targets = [
    {% set all_targets = [] %}
    {% for repo, entries in settings.items() %}
      {% for entry in entries if include_eol or ('eol' not in entry) %}
        {% for t in entry['targets'] %}
          {% set _ = all_targets.append(repo ~ '-' ~ entry['name'] ~ '-' ~ t['target']) %}
        {% endfor %}
      {% endfor %}
    {% endfor %}
    {{ all_targets | map('tojson') | join(', ') }}
  ]
}
